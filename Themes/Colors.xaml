<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BgBase">#FF0A0A0A</Color>
    <Color x:Key="BgSurface">#FF111111</Color>
    <Color x:Key="BgElevated">#FF161616</Color>
    <Color x:Key="BgHover">#FF1C1C1C</Color>
    <Color x:Key="BgPressed">#FF222222</Color>

    <Color x:Key="Border">#FF1F1F1F</Color>
    <Color x:Key="BorderStrong">#FF2A2A2A</Color>
    <Color x:Key="BorderAccent">#FF3A3A3A</Color>

    <Color x:Key="TextPrimary">#FFEDEDED</Color>
    <Color x:Key="TextSecondary">#FFA1A1A1</Color>
    <Color x:Key="TextMuted">#FF6B6B6B</Color>
    <Color x:Key="TextDisabled">#FF4A4A4A</Color>

    <Color x:Key="Accent">#FF7C5CFF</Color>
    <Color x:Key="AccentHover">#FF8F74FF</Color>
    <Color x:Key="AccentPressed">#FF6B4BEE</Color>
    <Color x:Key="AccentSoft">#221E1740</Color>

    <Color x:Key="Success">#FF00D084</Color>
    <Color x:Key="Warning">#FFF5A623</Color>
    <Color x:Key="Danger">#FFFF4D4F</Color>
    <Color x:Key="Info">#FF38BDF8</Color>

    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}" />
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}" />
    <SolidColorBrush x:Key="BgPressedBrush" Color="{StaticResource BgPressed}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccent}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource Info}" />

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7C5CFF" Offset="0" />
        <GradientStop Color="#FFEC4899" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF7C5CFF" Offset="0" />
        <GradientStop Color="#FF38BDF8" Offset="0.5" />
        <GradientStop Color="#FFEC4899" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
