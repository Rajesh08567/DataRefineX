<Window x:Class="DataRefineX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:conv="clr-namespace:DataRefineX.Converters"
        xmlns:models="clr-namespace:DataRefineX.Models"
        xmlns:vm="clr-namespace:DataRefineX.ViewModels"
        mc:Ignorable="d"
        Title="DataRefineX"
        Width="1180" Height="740"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/DataRefineX.ico"
        AllowDrop="True"
        Background="{StaticResource BgBaseBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource FontFamilyBase}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="InvertBoolToVisibility" Invert="True" />
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
        <conv:CountToVisibilityConverter x:Key="InvertCountToVisibility" Invert="True" />
        <conv:FileStatusToBrushConverter x:Key="FileStatusToBrush" />
        <conv:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        <conv:LongToNumberConverter x:Key="LongToNumber" />
        <conv:NullOrEmptyToVisibilityConverter x:Key="NonEmptyToVisibility" />
        <conv:EnumMatchConverter x:Key="EnumMatch" />
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Border BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1"
            Background="{StaticResource BgBaseBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ============= TITLE BAR ============= -->
            <Grid Grid.Row="0" Height="36" Background="{StaticResource BgBaseBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Margin="14,0,0,0" VerticalAlignment="Center">
                    <Image Width="20" Height="20"
                           Source="pack://application:,,,/Assets/logo-64.png"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Text="DataRefineX" />
                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="{Binding AppVersionDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{StaticResource IconButton}" Click="MinimizeButton_Click">
                        <Path Data="M 0,5 L 10,5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource IconButton}" Click="MaximizeButton_Click">
                        <Path Data="M 0,0 L 10,0 L 10,10 L 0,10 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1"
                              Fill="Transparent" />
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseIconButton}" Click="CloseButton_Click">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============= CONTENT ============= -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}" />
                </ScrollViewer.Resources>
            <Grid Margin="32,14,32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Update banner -->
                    <RowDefinition Height="Auto" />
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Sheet selection -->
                    <RowDefinition Height="Auto" />
                    <!-- Drop zone + stats -->
                    <RowDefinition Height="Auto" />
                    <!-- Queue + log -->
                    <RowDefinition Height="Auto" />
                    <!-- Progress -->
                    <RowDefinition Height="Auto" />
                    <!-- Actions -->
                </Grid.RowDefinitions>

                <!-- UPDATE BANNER -->
                <Border Grid.Row="0"
                        Margin="0,0,0,16"
                        Padding="16,12"
                        CornerRadius="10"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource BorderAccentBrush}"
                        BorderThickness="1"
                        Visibility="{Binding IsUpdateBannerVisible, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Icon dot -->
                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                Width="28" Height="28"
                                CornerRadius="999"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Background="{StaticResource AccentGradient}">
                            <Path Data="M 7,10 L 10,13 L 16,7"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>

                        <!-- Text -->
                        <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource BodyText}"
                                       FontWeight="SemiBold"
                                       Text="Update available" />
                            <TextBlock Margin="8,0,0,0"
                                       Style="{StaticResource BodyText}"
                                       FontFamily="Consolas, Cascadia Mono"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding UpdateVersionDisplay}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Grid.Row="1"
                                   Margin="0,2,0,0"
                                   Style="{StaticResource SecondaryText}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Text="{Binding UpdateInfo.ReleaseNotes, TargetNullValue='A new version is ready to install.', FallbackValue='A new version is ready to install.'}" />

                        <!-- Actions (static state) -->
                        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource InvertBoolToVisibility}}">
                            <Button Style="{StaticResource GhostButton}"
                                    Padding="10,6" FontSize="12"
                                    Content="Later"
                                    Command="{Binding DismissUpdateCommand}" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="14,6" FontSize="12"
                                    Content="Update now"
                                    Command="{Binding UpdateNowCommand}" />
                        </StackPanel>

                        <!-- Actions (downloading state) -->
                        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    MinWidth="220"
                                    Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel VerticalAlignment="Center" MinWidth="180">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource BodyText}"
                                               FontSize="12"
                                               Text="Downloading" />
                                    <TextBlock Margin="6,0,0,0"
                                               Style="{StaticResource BodyText}"
                                               FontFamily="Consolas, Cascadia Mono"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="{Binding UpdateProgress, StringFormat={}{0:0}%}" />
                                </StackPanel>
                                <ProgressBar Margin="0,6,0,0"
                                             Style="{StaticResource ThinProgressBar}"
                                             Value="{Binding UpdateProgress, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- HEADER -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource TitleText}"
                                   Text="DataRefineX" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource SecondaryText}"
                                   FontSize="14"
                                   Text="Clean, merge, and deduplicate Excel &amp; CSV data — pick any column as the unique key." />
                    </StackPanel>
                    <Border Grid.Column="1"
                            VerticalAlignment="Top"
                            Padding="10,5"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource BorderAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                            <TextBlock Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- SETTINGS: collapsible header + two-column Read | Write panels -->
                <Border Grid.Row="2" Margin="0,0,0,14" Style="{StaticResource Card}" Padding="0"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBool}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Header bar with collapse toggle -->
                        <Grid Grid.Row="0" Margin="20,14,20,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource H2Text}" Text="Settings" />
                                <TextBlock Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           Text="Configure how files are read on the left, and how output is written on the right." />
                            </StackPanel>
                            <ToggleButton x:Name="SettingsToggle"
                                          Grid.Column="1"
                                          IsChecked="True"
                                          Cursor="Hand"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="8,4"
                                          ToolTip="Show / hide settings to free up space.">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{TemplateBinding Tag}" VerticalAlignment="Center"
                                                           Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter Property="Tag" Value="▾  Hide" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter Property="Tag" Value="▸  Show" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgHoverBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>

                        <!-- Two-column body -->
                        <Grid Grid.Row="1" Margin="20,4,20,18"
                              Visibility="{Binding ElementName=SettingsToggle, Path=IsChecked, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ============ LEFT: READ ============ -->
                            <Border Grid.Column="0" Padding="16"
                                    Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="6"
                                                Background="{StaticResource AccentSoftBrush}">
                                            <Path Data="M 5,4 L 5,16 L 13,16 M 5,4 L 13,4 L 13,12 L 17,12"
                                                  Stroke="{StaticResource AccentBrush}"
                                                  StrokeThickness="1.5"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Style="{StaticResource H2Text}" Text="Read" />
                                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                   Style="{StaticResource MutedText}"
                                                   Text="What goes in" />
                                    </StackPanel>

                                    <!-- Sheets -->
                                    <TextBlock Margin="0,14,0,6" Style="{StaticResource LabelText}" Text="WHICH SHEETS" />
                                    <WrapPanel>
                                        <RadioButton GroupName="SheetMode" Margin="0,0,16,6"
                                                     Content="All sheets"
                                                     ToolTip="Read every sheet in every workbook. Best when you don't know the sheet names ahead of time."
                                                     IsChecked="{Binding SheetMode, Converter={StaticResource EnumMatch}, ConverterParameter=All, Mode=TwoWay}" />
                                        <RadioButton GroupName="SheetMode" Margin="0,0,16,6"
                                                     Content="By name"
                                                     ToolTip="Only sheets whose names match the list you provide. Supports * wildcards (e.g. Data*, Sheet?)."
                                                     IsChecked="{Binding SheetMode, Converter={StaticResource EnumMatch}, ConverterParameter=ByName, Mode=TwoWay}" />
                                        <RadioButton GroupName="SheetMode" Margin="0,0,16,6"
                                                     Content="First N"
                                                     ToolTip="Read only the first N sheets of each workbook in tab order."
                                                     IsChecked="{Binding SheetMode, Converter={StaticResource EnumMatch}, ConverterParameter=FirstN, Mode=TwoWay}" />
                                        <RadioButton GroupName="SheetMode" Margin="0,0,16,6"
                                                     Content="Legacy"
                                                     ToolTip="Original DataRefineX behavior — only reads sheets named 'Valid+BasicCheck+DEA' or 'CatchAll_AcceptAll'."
                                                     IsChecked="{Binding SheetMode, Converter={StaticResource EnumMatch}, ConverterParameter=Default, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <StackPanel Margin="0,4,0,0"
                                                Visibility="{Binding IsByNameMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBox FontFamily="Consolas, Cascadia Mono" FontSize="12"
                                                 ToolTip="Comma-separated names. * matches anything (e.g. Data*, *2024)."
                                                 Text="{Binding SheetNamesText, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedText}"
                                                   Text="e.g. Sheet1, Data*  •  case-insensitive  •  * = wildcard" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                Visibility="{Binding IsFirstNMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource SecondaryText}" FontSize="12" Text="Read the first" />
                                        <TextBox Margin="6,0,6,0" Width="56"
                                                 FontFamily="Consolas, Cascadia Mono" FontSize="12"
                                                 HorizontalContentAlignment="Center"
                                                 ToolTip="Number of sheets to read from the start of each workbook."
                                                 Text="{Binding FirstNSheets, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource SecondaryText}" FontSize="12" Text="sheet(s) per file." />
                                    </StackPanel>

                                    <!-- Dedup key -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="HOW TO DETECT DUPLICATES" />
                                    <WrapPanel>
                                        <RadioButton GroupName="DedupMode" Margin="0,0,16,6"
                                                     Content="Single column"
                                                     ToolTip="Most common — pick one column (like 'email' or 'phone') as the unique identifier."
                                                     IsChecked="{Binding DedupMode, Converter={StaticResource EnumMatch}, ConverterParameter=SingleColumn, Mode=TwoWay}" />
                                        <RadioButton GroupName="DedupMode" Margin="0,0,16,6"
                                                     Content="Multiple columns"
                                                     ToolTip="A row is a duplicate only when ALL listed columns match (e.g. first_name + last_name + phone)."
                                                     IsChecked="{Binding DedupMode, Converter={StaticResource EnumMatch}, ConverterParameter=MultipleColumns, Mode=TwoWay}" />
                                        <RadioButton GroupName="DedupMode" Margin="0,0,16,6"
                                                     Content="Whole row"
                                                     ToolTip="A row is a duplicate only when every single column matches another row exactly."
                                                     IsChecked="{Binding DedupMode, Converter={StaticResource EnumMatch}, ConverterParameter=EntireRow, Mode=TwoWay}" />
                                        <RadioButton GroupName="DedupMode" Margin="0,0,16,6"
                                                     Content="None"
                                                     ToolTip="Skip dedup entirely. Use this when you only want validation/cleanup."
                                                     IsChecked="{Binding DedupMode, Converter={StaticResource EnumMatch}, ConverterParameter=None, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <!-- Single column picker -->
                                    <StackPanel Margin="0,4,0,0"
                                                Visibility="{Binding IsSingleColumnDedup, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Style="{StaticResource SecondaryText}" FontSize="12"
                                                   Text="Unique column" />
                                        <ComboBox Margin="0,4,0,0"
                                                  IsEditable="True" StaysOpenOnEdit="True"
                                                  ItemsSource="{Binding DetectedColumns}"
                                                  Text="{Binding DedupColumn, UpdateSourceTrigger=LostFocus}"
                                                  ToolTip="Pick a column auto-detected from your files, or type any column name. Drop files first to detect columns." />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedText}"
                                                   Text="Auto-detected from your files. Type a name if it isn't listed." />
                                    </StackPanel>

                                    <!-- Multi-column input -->
                                    <StackPanel Margin="0,4,0,0"
                                                Visibility="{Binding IsMultiColumnDedup, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Style="{StaticResource SecondaryText}" FontSize="12"
                                                   Text="Columns to combine" />
                                        <TextBox Margin="0,4,0,0"
                                                 FontFamily="Consolas, Cascadia Mono" FontSize="12"
                                                 ToolTip="Comma-separated list. ALL columns must match for two rows to be duplicates."
                                                 Text="{Binding DedupColumnsText, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedText}"
                                                   Text="e.g. first_name, last_name, phone — match on ALL three" />
                                    </StackPanel>

                                    <!-- Case sensitivity -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="MATCHING" />
                                    <CheckBox Content="Case-sensitive matching"
                                              ToolTip="OFF (default): 'Foo' and 'foo' are treated as duplicates. Best for emails, names, most text.&#x0a;ON: 'Foo' and 'foo' are different. Use for case-significant IDs, hashes, codes, file paths."
                                              IsChecked="{Binding CaseSensitive}" />

                                    <!-- Multi-value split -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="MULTI-VALUE CELLS" />
                                    <CheckBox Content="Split cells with multiple values into separate rows"
                                              ToolTip="When ON, a cell like 'a@x.com; b@x.com; c@x.com' becomes 3 rows — each gets its own copy of the other columns. Useful when a single cell holds many emails/values."
                                              IsChecked="{Binding SplitMultiValueCells}" />
                                    <Grid Margin="24,6,0,0"
                                          Visibility="{Binding SplitMultiValueCells, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Style="{StaticResource SecondaryText}" FontSize="12"
                                                   Text="Separators:" />
                                        <TextBox Grid.Column="1"
                                                 MaxWidth="160" HorizontalAlignment="Left"
                                                 FontFamily="Consolas, Cascadia Mono" FontSize="12"
                                                 ToolTip="Each character is treated as a separator. Spaces are ignored. Default: ; , |"
                                                 Text="{Binding MultiValueDelimiters, UpdateSourceTrigger=LostFocus}" />
                                    </Grid>
                                    <TextBlock Margin="24,4,0,0" Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding SplitMultiValueCells, Converter={StaticResource BoolToVisibility}}"
                                               Text="Each character above acts as a separator. Only the unique column gets split; other columns are duplicated to each new row." />

                                    <!-- Validation -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="VALIDATE THE UNIQUE COLUMN" />
                                    <TextBlock Margin="0,0,0,6" Style="{StaticResource MutedText}"
                                               Text="Tick any combination — failed rows go to the Invalid bucket. Leave both unticked to skip validation." />
                                    <WrapPanel>
                                        <CheckBox Margin="0,0,18,6" Content="Email format"
                                                  ToolTip="Reject rows where the unique column isn't a valid email address."
                                                  IsChecked="{Binding ValidateEmail}" />
                                        <CheckBox Margin="0,0,18,6" Content="Not empty"
                                                  ToolTip="Reject rows where the unique column is empty or whitespace-only."
                                                  IsChecked="{Binding ValidateNotEmpty}" />
                                    </WrapPanel>

                                    <!-- Detected columns summary (fills empty space, useful info) -->
                                    <Border Margin="0,18,0,0" Padding="12,10"
                                            Background="{StaticResource BgPressedBrush}"
                                            CornerRadius="8"
                                            Visibility="{Binding DetectedColumns.Count, Converter={StaticResource CountToVisibility}}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource LabelText}"
                                                       Text="{Binding DetectedColumns.Count, StringFormat='COLUMNS DETECTED IN YOUR FILES ({0})'}" />
                                            <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding DetectedColumns}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2,6,2" Padding="8,3"
                                                                Background="{StaticResource BgElevatedBrush}"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="999">
                                                            <TextBlock FontFamily="Consolas, Cascadia Mono"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       Text="{Binding}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Margin="0,18,0,0" Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding DetectedColumns.Count, Converter={StaticResource InvertCountToVisibility}}"
                                               Text="Drop a file or fetch a Google Sheet to auto-detect columns." />
                                </StackPanel>
                            </Border>

                            <!-- ============ RIGHT: WRITE ============ -->
                            <Border Grid.Column="2" Padding="16"
                                    Background="{StaticResource BgElevatedBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="6"
                                                Background="{StaticResource AccentSoftBrush}">
                                            <Path Data="M 5,4 L 13,4 L 17,8 L 17,16 L 5,16 Z M 13,4 L 13,8 L 17,8"
                                                  Stroke="{StaticResource AccentBrush}"
                                                  StrokeThickness="1.5"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Style="{StaticResource H2Text}" Text="Write" />
                                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                                   Style="{StaticResource MutedText}"
                                                   Text="What comes out" />
                                    </StackPanel>

                                    <!-- Destination -->
                                    <TextBlock Margin="0,14,0,6" Style="{StaticResource LabelText}" Text="DESTINATION" />
                                    <StackPanel>
                                        <RadioButton GroupName="OutputDest" Margin="0,0,0,6"
                                                     Content="New file (recommended)"
                                                     ToolTip="Writes a new 'Processed_*.xlsx/csv' file alongside the source — originals stay untouched."
                                                     IsChecked="{Binding OutputDestination, Converter={StaticResource EnumMatch}, ConverterParameter=NewFile, Mode=TwoWay}" />
                                        <RadioButton GroupName="OutputDest" Margin="0,0,0,6"
                                                     Content="Same file (overwrite source)"
                                                     ToolTip="DESTRUCTIVE — overwrites each source file with the cleaned data. Each file is dedup'd independently. Make a backup first!"
                                                     IsChecked="{Binding OutputDestination, Converter={StaticResource EnumMatch}, ConverterParameter=InPlace, Mode=TwoWay}" />
                                    </StackPanel>

                                    <Border Margin="0,4,0,0" Padding="10,8"
                                            Background="{StaticResource BgPressedBrush}"
                                            CornerRadius="6"
                                            Visibility="{Binding IsInPlace, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Text="⚠  Source files will be overwritten. Each file is processed independently (dedup is per-file, not across files)." />
                                    </Border>

                                    <!-- Sheet structure -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="SHEET STRUCTURE" />
                                    <StackPanel>
                                        <CheckBox Margin="0,0,0,6"
                                                  Content="Keep original sheet names"
                                                  ToolTip="ON: each input sheet becomes its own output sheet with the same name (deduplicated within itself).&#x0a;OFF: all unique rows merge into a single 'Unique' sheet."
                                                  IsChecked="{Binding PreserveSourceSheets}" />
                                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                                   Text="If you upload a workbook with sheets 'Customers' and 'Vendors', the output will keep both names — duplicates are removed inside each sheet independently." />
                                    </StackPanel>

                                    <!-- Buckets -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="WHAT TO INCLUDE" />
                                    <StackPanel>
                                        <CheckBox Margin="0,0,0,6" Content="Unique rows"
                                                  ToolTip="The cleaned, deduplicated data — the main output."
                                                  IsChecked="{Binding WriteUniqueSheet}" />
                                        <CheckBox Margin="0,0,0,6" Content="Duplicates removed"
                                                  ToolTip="Rows that were detected as duplicates and dropped. Useful for auditing what was removed."
                                                  IsChecked="{Binding WriteDuplicatesSheet}" />
                                        <CheckBox Margin="0,0,0,6" Content="Invalid / empty"
                                                  ToolTip="Rows that failed validation (bad email, empty key column, etc.)."
                                                  IsChecked="{Binding WriteInvalidSheet}" />
                                    </StackPanel>

                                    <!-- Format -->
                                    <TextBlock Margin="0,16,0,6" Style="{StaticResource LabelText}" Text="FILE FORMAT" />
                                    <StackPanel Visibility="{Binding IsNewFile, Converter={StaticResource BoolToVisibility}}">
                                        <RadioButton GroupName="OutputFormat" Margin="0,0,0,6"
                                                     Content="XLSX — one workbook, multi-sheet"
                                                     ToolTip="Each enabled bucket becomes a sheet inside one Excel workbook."
                                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumMatch}, ConverterParameter=Xlsx, Mode=TwoWay}" />
                                        <RadioButton GroupName="OutputFormat" Margin="0,0,0,6"
                                                     Content="CSV — separate file per bucket"
                                                     ToolTip="Writes one CSV per enabled bucket (Processed_..._Unique.csv, etc.)."
                                                     IsChecked="{Binding OutputFormat, Converter={StaticResource EnumMatch}, ConverterParameter=Csv, Mode=TwoWay}" />
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding IsInPlace, Converter={StaticResource BoolToVisibility}}"
                                               Text="Format follows each source file (.xlsx → xlsx, .csv → csv)." />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- DROP ZONE + STATS -->
                <Grid Grid.Row="3" Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Google Sheets URL bar -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2"
                            Margin="0,0,0,12"
                            Padding="14,12"
                            CornerRadius="10"
                            Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <!-- Title row -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Border Width="22" Height="22"
                                        CornerRadius="6"
                                        Background="{StaticResource AccentSoftBrush}"
                                        VerticalAlignment="Center">
                                    <Path Data="M 4,3 L 11,3 L 14,6 L 14,15 L 4,15 Z M 11,3 L 11,6 L 14,6"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                           Style="{StaticResource H2Text}" FontSize="13"
                                           Text="Or paste a Google Sheets URL" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           Text="(must be shared as 'Anyone with the link')" />
                            </StackPanel>

                            <!-- Input row: textbox + button on one line, equal heights -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         MinHeight="40"
                                         Padding="12,10"
                                         FontFamily="Consolas, Cascadia Mono" FontSize="12"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Paste a Google Sheets share link. The whole workbook will be downloaded as .xlsx and added to the queue."
                                         Text="{Binding GoogleSheetUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <Button Grid.Column="1"
                                        Margin="10,0,0,0"
                                        MinHeight="40"
                                        MinWidth="120"
                                        Padding="20,8"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AddGoogleSheetCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Grid Width="14" Height="14" Margin="0,0,8,0"
                                          Visibility="{Binding IsFetchingGoogleSheet, Converter={StaticResource BoolToVisibility}}">
                                        <Ellipse Stroke="#66FFFFFF" StrokeThickness="2" />
                                        <Ellipse Stroke="White" StrokeThickness="2" StrokeDashArray="6 14" RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="360" Duration="0:0:1.2" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock VerticalAlignment="Center"
                                               Text="Fetching..."
                                               Visibility="{Binding IsFetchingGoogleSheet, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="Fetch"
                                               Visibility="{Binding IsFetchingGoogleSheet, Converter={StaticResource InvertBoolToVisibility}}" />
                                </StackPanel>
                            </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                <!-- Drop zone + stats inner grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="DropZone"
                            Grid.Column="0"
                            Margin="0,0,16,0"
                            Style="{StaticResource Card}"
                            MinHeight="140"
                            Cursor="Hand"
                            AllowDrop="True"
                            MouseLeftButtonUp="DropZone_MouseLeftButtonUp"
                            DragEnter="DropZone_DragEnter"
                            DragOver="DropZone_DragOver"
                            DragLeave="DropZone_DragLeave"
                            Drop="DropZone_Drop">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Grid Width="52" Height="52" HorizontalAlignment="Center">
                                    <Ellipse Fill="{StaticResource AccentSoftBrush}" />
                                    <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M 12,20 L 12,4 M 4,12 L 12,4 L 20,12"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" />
                                </Grid>
                                <TextBlock Margin="0,14,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="Drag &amp; drop spreadsheets here" />
                                <TextBlock Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource SecondaryText}"
                                           Text="or click to browse  •  .xlsx / .xlsm / .csv  •  bulk upload supported" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource Card}"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Style="{StaticResource LabelText}"
                                       Text="PIPELINE STATS" />

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                                <TextBlock Style="{StaticResource SecondaryText}" FontSize="11" Text="Total rows read" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource MetricValueText}"
                                           Text="{Binding Stats.TotalRowsRead, Converter={StaticResource LongToNumber}}" />

                                <TextBlock Margin="0,16,0,0"
                                           Style="{StaticResource SecondaryText}"
                                           FontSize="11"
                                           Text="Duplicates removed" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource MetricValueText}"
                                           Foreground="{StaticResource WarningBrush}"
                                           Text="{Binding Stats.DuplicatesRemoved, Converter={StaticResource LongToNumber}}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,14,0,0">
                                <TextBlock Style="{StaticResource SecondaryText}" FontSize="11" Text="Invalid removed" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource MetricValueText}"
                                           Foreground="{StaticResource DangerBrush}"
                                           Text="{Binding Stats.InvalidRemoved, Converter={StaticResource LongToNumber}}" />

                                <TextBlock Margin="0,16,0,0"
                                           Style="{StaticResource SecondaryText}"
                                           FontSize="11"
                                           Text="Valid records" />
                                <TextBlock Margin="0,2,0,0"
                                           Style="{StaticResource MetricValueText}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           Text="{Binding Stats.ValidRecords, Converter={StaticResource LongToNumber}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>

                <!-- QUEUE + LOG -->
                <Grid Grid.Row="4" Height="280">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,16,0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="20,18,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource H2Text}" Text="File queue" />
                                    <Border Margin="10,0,0,0"
                                            Background="{StaticResource BgHoverBrush}"
                                            CornerRadius="999"
                                            Padding="7,2">
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   Text="{Binding Files.Count, StringFormat={}{0} files}" />
                                    </Border>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource GhostButton}"
                                        Padding="10,6"
                                        FontSize="12"
                                        Content="Browse..."
                                        Click="BrowseButton_Click"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBool}}" />
                            </Grid>

                            <StackPanel Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,0,0,16"
                                        Visibility="{Binding QueueEmptyHint, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock HorizontalAlignment="Center"
                                           Style="{StaticResource SecondaryText}"
                                           Text="No files yet" />
                                <TextBlock Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           Text="Drop Excel files above to queue them" />
                            </StackPanel>

                            <ListBox Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="10,0,10,10"
                                     ItemContainerStyle="{StaticResource FlatListItem}"
                                     ItemsSource="{Binding Files}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="{x:Type ListBox}">
                                        <ScrollViewer Focusable="False"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ScrollViewer.Resources>
                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}" />
                                            </ScrollViewer.Resources>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:FileItem}">
                                        <Border Margin="10,4"
                                                Padding="14,12"
                                                Background="{StaticResource BgElevatedBrush}"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="14" Height="14" VerticalAlignment="Center">
                                                    <Ellipse Fill="{Binding Status, Converter={StaticResource FileStatusToBrush}}"
                                                             Visibility="{Binding IsActive, Converter={StaticResource InvertBoolToVisibility}}" />
                                                    <Grid Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}">
                                                        <Ellipse Stroke="{StaticResource BorderStrongBrush}" StrokeThickness="2" />
                                                        <Ellipse x:Name="SpinArc"
                                                                 Stroke="{StaticResource InfoBrush}"
                                                                 StrokeThickness="2"
                                                                 StrokeDashArray="6 14"
                                                                 RenderTransformOrigin="0.5,0.5">
                                                            <Ellipse.RenderTransform>
                                                                <RotateTransform Angle="0" />
                                                            </Ellipse.RenderTransform>
                                                            <Ellipse.Triggers>
                                                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                                    <BeginStoryboard>
                                                                        <Storyboard RepeatBehavior="Forever">
                                                                            <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                                                                             From="0" To="360" Duration="0:0:1.2" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Ellipse.Triggers>
                                                        </Ellipse>
                                                    </Grid>
                                                </Grid>

                                                <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Style="{StaticResource MutedText}" Text="{Binding SizeDisplay}" />
                                                        <TextBlock Style="{StaticResource MutedText}"
                                                                   Text="  •  "
                                                                   Visibility="{Binding RowsDisplay, Converter={StaticResource NonEmptyToVisibility}}" />
                                                        <TextBlock Style="{StaticResource MutedText}" Text="{Binding RowsDisplay}" />
                                                        <TextBlock Style="{StaticResource MutedText}"
                                                                   Text="  •  "
                                                                   Visibility="{Binding Message, Converter={StaticResource NonEmptyToVisibility}}" />
                                                        <TextBlock Style="{StaticResource MutedText}" Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Padding="9,3"
                                                        Background="{StaticResource BgHoverBrush}"
                                                        CornerRadius="999">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="Medium"
                                                               Foreground="{Binding Status, Converter={StaticResource FileStatusToBrush}}"
                                                               Text="{Binding StatusText}" />
                                                </Border>

                                                <Button Grid.Column="4"
                                                        Margin="8,0,0,0"
                                                        Style="{StaticResource IconButton}"
                                                        Width="28" Height="28"
                                                        Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Remove">
                                                    <Path Data="M 0,0 L 8,8 M 8,0 L 0,8"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.2" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="20,18,20,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource H2Text}"
                                           Text="Activity" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           Text="{Binding Stats.ElapsedDisplay}" />
                            </Grid>

                            <ListBox x:Name="LogList"
                                     Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12,0,12,12"
                                     ItemContainerStyle="{StaticResource FlatListItem}"
                                     ItemsSource="{Binding Logs}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="{x:Type ListBox}">
                                        <ScrollViewer x:Name="LogScroll"
                                                      Focusable="False"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ScrollViewer.Resources>
                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}" />
                                            </ScrollViewer.Resources>
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:LogEntry}">
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Top"
                                                       Style="{StaticResource MutedText}"
                                                       FontFamily="Consolas, Cascadia Mono"
                                                       Text="{Binding TimeDisplay}" />
                                            <Ellipse Grid.Column="1"
                                                     Margin="10,6,10,0"
                                                     Width="6" Height="6"
                                                     VerticalAlignment="Top"
                                                     Fill="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                            <TextBlock Grid.Column="2"
                                                       Style="{StaticResource BodyText}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Message}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- PROGRESS -->
                <Border Grid.Row="5" Margin="0,20,0,0" Style="{StaticResource Card}" Padding="20,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Style="{StaticResource H2Text}" Text="Overall progress" />
                                <TextBlock Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           Text="{Binding CurrentFile, StringFormat={}• {0}}"
                                           Visibility="{Binding CurrentFile, Converter={StaticResource NonEmptyToVisibility}}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       FontFamily="Consolas, Cascadia Mono"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding OverallProgress, StringFormat={}{0:0.0}%}" />
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Style="{StaticResource ThinProgressBar}"
                                     Value="{Binding OverallProgress, Mode=OneWay}" />
                    </Grid>
                </Border>

                <!-- ACTIONS -->
                <Grid Grid.Row="6" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" />
                        <TextBlock Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource BodyText}"
                                   FontWeight="Medium"
                                   Text="Done — output saved." />
                        <Button Margin="14,0,0,0"
                                Style="{StaticResource GhostButton}"
                                Padding="12,7"
                                FontSize="12"
                                Content="Open file"
                                Command="{Binding OpenOutputCommand}" />
                        <Button Margin="8,0,0,0"
                                Style="{StaticResource GhostButton}"
                                Padding="12,7"
                                FontSize="12"
                                Content="Show in folder"
                                Command="{Binding OpenOutputFolderCommand}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource GhostButton}"
                                Content="Clear"
                                Command="{Binding ClearCommand}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource GhostButton}"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="180"
                                Content="Start processing"
                                Command="{Binding StartCommand}"
                                Visibility="{Binding NotProcessing, Converter={StaticResource BoolToVisibility}}" />
                        <Button Margin="10,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="180"
                                IsEnabled="False"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="14" Height="14" Margin="0,0,8,0">
                                    <Ellipse Stroke="#66FFFFFF" StrokeThickness="2" />
                                    <Ellipse Stroke="White" StrokeThickness="2" StrokeDashArray="6 14" RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(Ellipse.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="360" Duration="0:0:1.2" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                </Grid>
                                <TextBlock VerticalAlignment="Center" Text="Processing..." />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
